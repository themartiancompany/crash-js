function
  _argv_url_get(
    _key_name) {
  let
    _argv,
    _assignment,
    _assignments,
    _key,
    _key_value,
    _location,
    _msg,
    _url,
    _value;
  if ( typeof _key_name === 'undefined' ) {
    _msg =
      "Getting all values."
    _msg_info(
      _msg);
    _key_name =
      "";
  }
  _argv =
    [];
  _location =
    window.location;
  _url =
    _location.search.substring(
      1);
  _assignments =
    _url.split(
      '&');
  for ( let
          _result =
            0;
        _result <
          _assignments.length;
        _result++ ) {
    _assignment =
      _assignments[
        _result];
    _key_value =
      _assignment.split(
        '=');
    _key =
      _key_value[
        0];
    if ( _key == _key_name ||
         _key_name == "" ) {
      _value =
        _key_value[
          1];
      _argv.push(
        _value);
    }
  }
  return _argv;
}

function
  _argv_get(
    _args) {
  let
    _argv;
  if ( typeof window === 'undefined' &&
       ( typeof global !== 'undefined' && global.global === global ) &&
       typeof __webpack_require__ !== 'function' ) {
    _argv =
      _yargv_get(
        _args);
  }
  else {
    _argv =
      _argv_url_get();
  }
  return _argv;
}

function
  _yargv_get(
    _args) {
  let
    _boolean;
  const
    _yargs_opts =
      {};
  const
    _parser_opts =
      {};
  if ( typeof(
          _args) == "undefined" ||
       _args == {} ||
       _args == "" ) {
    _args = {
      "booleans": [],
      "string": true
    };
  }
  const
    _booleans =
      _args[
        "booleans"];
  if ( typeof window === 'undefined' &&
       ( typeof global !== 'undefined' && global.global === global ) ) {
    const
      _yargs =
        require(
          "yargs");
    _yargs_helpers_module =
      require(
        "yargs/helpers");
    const
      _hide_bin =
        _yargs_helpers_module.hideBin;
    if ( "string" in _args &&
         _args[
           "string"] ) {
      _yargs_opts[
        "_"] = {
        "type":
          "string",
        "string":
          true
      };
      _parser_opts[
        "parse-numbers"] =
        false;
      _parser_opts[
        "parse-positional-numbers"] =
        false;
    }
    if ( _booleans.length > 0 ) {
      for ( _boolean of _booleans) {
        _yargs_opts[
          _boolean] = {
            "demand":
              false,
            "default":
              false,
            "type":
              "boolean",
         };
      }
    }
    if ( 0 < _booleans.length ||
         _args[
           "string"] ) {
      return _yargs(
               _hide_bin(
                 process.argv)).parserConfiguration(
                   _parser_opts).options(
                _yargs_opts).string(
                  "_").parse();
    }
    else {
      return _yargs(
        _hide_bin(
          process.argv));
    }
  }
}

