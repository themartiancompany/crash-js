function
  _argv_url_get(
    _key_name) {
  let
    _argv,
    _assignment,
    _assignments,
    _key,
    _key_value,
    _location,
    _msg,
    _url,
    _value;
  if ( typeof _key_name === 'undefined' ) {
    _msg =
      "Getting all values."
    _msg_info(
      _msg);
    _key_name =
      "";
  }
  _argv =
    [];
  _location =
    window.location;
  _url =
    _location.search.substring(
      1);
  _assignments =
    _url.split(
      '&');
  for ( let
          _result =
            0;
        _result <
          _assignments.length;
        _result++ ) {
    _assignment =
      _assignments[
        _result];
    _key_value =
      _assignment.split(
        '=');
    _key =
      _key_value[
        0];
    if ( _key == _key_name ||
         _key_name == "" ) {
      _value =
        _key_value[
          1];
      _argv.push(
        _value);
    }
  }
  return _argv;
}

function
  _argv_get() {
  let
    _argv;
  if ( typeof window === 'undefined' &&
       ( typeof global !== 'undefined' && global.global === global ) &&
       typeof __webpack_require__ !== 'function' ) {
    _argv =
      _yargv_get();
  }
  else {
    _argv =
      _argv_url_get();
  }
  return _argv;
}

function
  _yargv_get() {
  let
    _argv,
    _hide_bin,
    _yargs,
    _yargs_object;
  if ( typeof window === 'undefined' &&
       ( typeof global !== 'undefined' && global.global === global ) ) {
    _yargs =
      require(
        "yargs");
    _yargs_helpers_module =
      require(
        "yargs/helpers");
    _hide_bin =
      _yargs_helpers_module.hideBin;
    _yargs_object =
      _yargs(
        _hide_bin(
          process.argv));
    return _yargs_object.parse();
  }
}

function
  _process_exit_get() {
  let
    _process_exit;
  if ( typeof window === 'undefined' &&
       ( typeof global !== 'undefined' && global.global === global ) &&
       typeof __webpack_require__ !== 'function' ) {
    _process_exit =
      process.exit;
  }
  else {
    _process_exit =
      function
        (_exit) {
        return _exit;
     };
  }
  return _process_exit
}


function
  _process_cwd_get() {
  let
    _process_cwd;
  if ( typeof window === 'undefined' &&
       ( typeof global !== 'undefined' && global.global === global ) &&
       typeof __webpack_require__ === 'function' ) {
    _process_cwd =
      process.cwd;
  }
  else {
    _process_cwd =
      function
        () {
        return ".";
     };
  }
  return _process_cwd
}

function
  _range(
    _start,
    _end) {
  let
    _length;
  if ( typeof(
         _end) === 'undefined' ) {
    _end =
      _start;
    _start =
      0;
  }
  _length =
    _end -
    _start;
  if ( _length < 0 ) {
    _msg =
      `Second argument 'end' ` +
      `must be greater than first ` +
      `argument 'start'.`;
    _msg_error(
      _msg,
      1);
  }
  return Array(
           _length).keys().map(
             _index =>
               _index + _start);
}

function
  _seq(
    _start,
    _end) {
  let
    _item,
    _list;
  _list =
    [];
  if ( typeof(
         _end) === 'undefined' ) {
    _end =
      _start;
    _start =
      1;
  }
  console.log(
    "hi");
  console.log(
    _range(
      _start,
      _end));
  for ( _item of _range(
                   _start,
                   _end + 1) ) {
    console.log(_item);
    _list.push(
      _item);
  }
  return _list;
}

module.exports = {
  _argv_get:
    _argv_get,
  _argv_url_get:
    _argv_url_get,
  _process_exit_get:
    _process_exit_get,
  _process_cwd_get:
    _process_cwd_get,
  _range:
    _range,
  _seq:
    _seq,
  _yargv_get:
    _yargv_get
};
