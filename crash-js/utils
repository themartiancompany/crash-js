function
  _child_process_spawn_get(
    _spawn_type) {
  let
    _child_process_spawn;
  if ( typeof(
         _spawn_type) == "undefined" ||
       _spawn_type == "" ) {
    _spawn_type =
      "sync";
  }
  if ( typeof window === 'undefined' &&
       ( typeof global !== 'undefined' && global.global === global ) &&
       typeof __webpack_require__ !== 'function' ) {
    const
      _child_process_module =
        require(
          "node:child_process");
    if ( _spawn_type == "sync" ) {
      _child_process_spawn =
        _child_process_module.spawnSync;
    }
    else if ( _spawn_type == "async" ) {
      _child_process_spawn =
        _child_process_module.spawn;
    }
  }
  else {
    _child_process_spawn =
      function
        (_cmd, _args, _exit) {
        return _exit;
     };
  }
  return _child_process_spawn;
}

module.exports = {
  _argv_get:
    _argv_get,
  _argv_url_get:
    _argv_url_get,
  _child_process_spawn_get:
    _child_process_spawn_get,
  _os_tmpdir_get:
    _os_tmpdir_get,
  _process_exit_get:
    _process_exit_get,
  _process_cwd_get:
    _process_cwd_get,
  _yargv_get:
    _yargv_get
};
