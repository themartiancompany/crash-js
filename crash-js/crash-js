function
  _app_name_get() {
  let
    _filename;
  _filename =
    _basename(
      __filename);
  return _filename;
}

function 
  _msg_template(
    _type,
    _app_name) {
  let
    _template;
  if ( typeof(
         _app_name) == "undefined" ||
       _app_name == "" ) {
    _template =
      `${_type}: {_msg}`;
  }
  else if ( typeof(
              _app_name) == "string" ||
            _app_name != "" ) {
      _template =
        `[${_app_name}] ${_type}: {_msg}`;
  }
  return _template;
}

function
  _msg_warning(
    _msg) {
  let
    _out;
  if ( quiet == "n" ) {
    _template =
      _msg_template(
        "WARNING",
        app_name);
    _out =
      _template.replaceAll(
        "{_msg}",
        _msg);
    console.warn(
      _out);
  }
}

function
  _msg_info(
    _msg) {
  let
    _out;
  if ( typeof(
         quiet) == "undefined" ||
       quiet == "" ) {
    quiet =
      "y";
  }
  if ( quiet == "n" ) {
    const
      _template =
        _msg_template(
          "INFO",
          app_name);
    _out =
      _template.replaceAll(
        "{_msg}",
        _msg);
    console.log(
      _out);
  }
}

function
  _msg_error(
    _msg,
    _exit) {
  let
    _template,
    _out;
  if ( typeof(
         app_name) == "undefined" ||
         app_name == "" ) {
    const
      app_name =
        "";
  }
  _exit =
    String(
      _exit);
  _template =
    _msg_template(
      "ERROR",
      app_name);
  _out =
    _template.replaceAll(
      "{_msg}",
      _msg);
  if ( _exit === "1" ) {
    console.error(
      _out);
    _process_exit(
      1);
  }
  else if ( _exit === "0" ) {
    console.warn(
      _out);
  }
}

function 
  _msg_info_obj(
    _name,
    _obj) {
  let
    _template,
    _partial,
    _msg;
  _msg =
    `${_name}: '${_obj}'`;
  _msg_info(
    _msg);
}

function
  _error_display(
    _error) {
  let
    _message;
  if ( typeof(error) == "object" ) {
    if ( 'error' in _error && 
         _error[
           'error'] != undefined &&
         'message' in _error[
                        'error'] ) {
      _message =
        _error[
          'error'][
            'message'];
    }
    else if ( 'shortMessage' in _error ) {
      _message =
        _error[
          'shortMessage'];
    }
    else {
      _message =
        _error;
    }
    console.error(
      _error);
  }
  else {
    _message =
      _error;
    console.error(
      _error);
  }
  _msg_error(
    _message,
    0);
}

function
  _cmdline_check(
    _app_name) {
  let
    _argv,
    _program,
    _program_name;
  if ( typeof window === 'undefined' ) {
    _argv =
      _argv_get();
    _program =
      _argv[
        1];
    if ( typeof(
           _program) === 'undefined' ) {
      _program =
        _argv[
          "$0"];
    }
    _program_name =
      _basename(
        _program);
    if ( _program_name == _app_name ) {
      return true;
    }
    else {
      return false;
    }
  }
  else {
    return false;
  }
}

function
  _get_date_human() {
  const
    _date =
      new Date();
  const
    _year =
      _date.getFullYear();
  const
    _month =
      _date.getMonth();
  const
    _day =
      _date.getDay();
  const
    _time =
      `${_date.getHours()}:${_date.getMinutes()}`;
  // Assume UTC
  const
    _zone =
      "0000"
  const
    _date_human =
      `${_year}-${_month}-${_day}T${_time}+${_zone}`;
  return _date_human;
}

// This function is actually not a format
// print, but just how the author of this
// library calls a display function which
// does not add a goddamn newline at the
// end of the input text to display
function
  _printf(
    _text) {
  let
    _stdout_write;
  if ( typeof window === 'undefined' ) {
    _stdout =
      process.stdout;
  }
  if ( typeof window != 'undefined' ) {
    _stdout =
      require(
        "stream-browserify");
  }
  _stdout.write(
    _text);
}

function
  _homedir_get() {
  let
    _home;
  if ( typeof window === 'undefined' &&
       ( typeof global !== 'undefined' && global.global === global ) &&
       typeof __webpack_require__ !== 'function' ) {
    _home =
      process.env.HOME;
  }
  if ( typeof(
         window) != "undefined" ) {
    _home =
      "/home/user";
  }
  return _home;
}

function
  _lib_get() {
  let
    _lib,
    _lib_path,
    _line,
    _out,
    _path,
    _words;
  const
    _paths =
      new Set();
  if ( typeof window === 'undefined' &&
       ( typeof global !== 'undefined' && global.global === global ) &&
       typeof __webpack_require__ !== 'function' ) {
    const
      _out =
        _run(
         "sync",
          [ "ldconfig",
            "-p" ]);
    const
      _tail =
        _out.slice(
          1,
          _out.length - 2);
    for ( _line of _tail ) {
      _words =
        _line.split(" ");
      _lib_path =
        _words[
          3];
      _lib =
        _dirname(
          _lib_path);
      _paths.add(
        _lib);
    }
    if ( typeof(
           process.env.NODE_PATH) == "undefined" ||
         process.env.NODE_PATH == "" ) {
      const
        _msg =
          "Environment variable NODE_PATH undefined.";
      _msg_info(
        _msg);
    }
    else {
      _lib =
        _path_join(
          [ process.env.NODE_PATH,
            "../lib" ]);
      if ( _file_exists(
             _lib) ) {
        _paths.add(
          _lib);
      }
    }
    for ( _path of _paths ) {
      return _path;
    }
  }
  else {
    _lib =
      "/usr/lib";
  }
  return _lib
}

function
  _echo(
    _text) {
  console.log(
    _text);
}

function
  _range(
    _start,
    _end) {
  let
    _length;
  if ( typeof(
         _end) === 'undefined' ) {
    _end =
      _start;
    _start =
      0;
  }
  _length =
    _end -
    _start;
  if ( _length < 0 ) {
    _msg =
      `Second argument 'end' ` +
      `is greater than first ` +
      `argument 'start', returning ` +
      `empty list.`;
    _msg_warning(
      _msg);
    return [];
  }
  return Array(
           _length).keys().map(
             _index =>
               _index + _start);
}

async function
  _run(
    _run_mode,
    _cmd,
    _name,
    _timeout,
    _run_type) {
  let
    _array,
    _index,
    _msg,
    _out;
  if ( typeof(
         _cmd) == "undefined" ||
       _cmd == "" ||
       _cmd == [] ) {
    _msg =
      "No command given in input.";
    _msg_error(
        _msg,
        1);
  }
  const
    _program =
      _cmd[
        0];
  const
    _args =
      _cmd.slice(
        1,
        _cmd.length);
  if ( typeof(
         _run_mode) == "undefined" ||
       _run_mode == "" ) {
    _run_mode =
      "sync";
  }
  if ( typeof(
         _name) == "undefined" ||
       _name == "" ) {
    _name =
      "";
  }
  if ( typeof(
         _timeout) == "undefined" ||
       _timeout == "" ) {
    _timeout =
      "0";
  }
  if ( typeof(
         _run_type) == "undefined" ||
       _run_type == "" ) {
    _run_type =
      "spawn";
  }
  _msg =
    `Running '${_program}' ` +
    `with arguments '${_args}'.`;
  _msg_info(
    _msg);
  _out =
    "";
  if ( _run_mode == "async" ) {
    // currently not working well id say
    const
      _print =
        function
          (_data) {
          _out = 
            _out +
            _data.toString();
        };
    const
      _close =
        function(
          _code) {
          let
            _array,
            _msg;
          if ( _code != 0 ) {
            _msg =
              `Process exited with code '${_code}'`;
            _msg_error(
              _msg,
              1);
          }
          else {
            _msg =
              `Process exited normally.`;
            _msg_info(
              _msg);
          }
          _array =
            _out.split("\n");
          return _array;
        };
    const
      _process =
        _spawn_async(
          _program,
          _args);
    _process.stdout.on(
      'data',
      _print);
    _process.on(
      'close',
      _close);
    _array =
      _out.split(
        "\n");
    _msg_info(
      _array.length);
    return _array;
  }
  else if ( _run_mode == "sync" ) {
    if ( _run_type == "spawn" ) {
      const
        _process =
          _spawn(
            _program,
            _args,
            { "encoding":
                "utf-8" });
      _array =
        _process.stdout.split(
          "\n");
      return _array;
    }
    else if ( _run_type == "native" ) {
      _time_over =
        false;
      const
        _exit_timeout =
          () => {
          return true;
        };
      _out =
        _program.apply(
          null,
          _args);
      const
        _exit_timeout =
          () => {
          _time_over =
            true;
          return true;
        };
      setTimeout(
        _exit_timeout,
        _timeout);
      await _out;
      if ( _time_over ) {
        _msg =
          `Timeout reached for task '${_name}'.`;
        throw _msg;
      }
      else {
        return _out;
      }
    }
  }
}

function
  _seq(
    _start,
    _end) {
  let
    _item,
    _list;
  _list =
    [];
  if ( _end < _start ) {
    _msg =
      `Second argument 'end' ` +
      `is greater than first ` +
      `argument 'start', returning ` +
      `empty list.`;
    _msg_warning(
      _msg);
    return _list;
  }
  if ( typeof(
         _end) === 'undefined' ) {
    _end =
      _start;
    _start =
      1;
  }
  for ( _item of _range(
                   _start,
                   _end + 1) ) {
    _list.push(
      _item);
  }
  return _list;
}

function
  _sleep(
    _time) {
  return new Promise(
               resolve => setTimeout(
                            resolve,
                            _time));
}

