async function
  _lib_get() {
  let
    _lib,
    _lib_path,
    _line,
    _out,
    _path,
    _words;
  const
    _paths =
      new Set();
  if ( typeof window === 'undefined' &&
       ( typeof global !== 'undefined' && global.global === global ) &&
       typeof __webpack_require__ !== 'function' ) {
    const
      _out =
        await _run(
         "sync",
          [ "ldconfig",
            "-p" ]);
    // console.log(_out);
    const
      _tail =
        _out.slice(
          1,
          _out.length - 2);
    for ( _line of _tail ) {
      _words =
        _line.split(" ");
      _lib_path =
        _words[
          3];
      _lib =
        _dirname(
          _lib_path);
      _paths.add(
        _lib);
    }
    if ( typeof(
           process.env.NODE_PATH) == "undefined" ||
         process.env.NODE_PATH == "" ) {
      const
        _msg =
          "Environment variable NODE_PATH undefined.";
      _msg_info(
        _msg);
    }
    else {
      _lib =
        _path_join(
          [ process.env.NODE_PATH,
            "../lib" ]);
      if ( _file_exists(
             _lib) ) {
        _paths.add(
          _lib);
      }
    }
    for ( _path of _paths ) {
      return _path;
    }
  }
  else {
    _lib =
      "/usr/lib";
  }
  return _lib
}

