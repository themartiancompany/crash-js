function
  _range(
    _start,
    _end) {
  let
    _length;
  if ( typeof(
         _end) === 'undefined' ) {
    _end =
      _start;
    _start =
      0;
  }
  _length =
    _end -
    _start;
  if ( _length < 0 ) {
    _msg =
      `Second argument 'end' ` +
      `is greater than first ` +
      `argument 'start', returning ` +
      `empty list.`;
    _msg_warning(
      _msg);
    return [];
  }
  return Array(
           _length).keys().map(
             _index =>
               _index + _start);
}

async function
  _run(
    _run_mode,
    _cmd,
    _name,
    _timeout,
    _run_type,
    _method) {
  let
    _array,
    _index,
    _msg,
    _out;
  if ( typeof(
         _cmd) == "undefined" ||
       _cmd == "" ||
       _cmd == [] ) {
    _msg =
      "No command given in input.";
    _msg_error(
        _msg,
        1);
  }
  const
    _program =
      _cmd[
        0];
  const
    _args =
      _cmd.slice(
        1,
        _cmd.length);
  if ( typeof(
         _run_mode) == "undefined" ||
       _run_mode == "" ) {
    _run_mode =
      "sync";
  }
  if ( typeof(
         _name) == "undefined" ||
       _name == "" ) {
    _name =
      "";
  }
  if ( typeof(
         _timeout) == "undefined" ||
       _timeout == "" ) {
    _timeout =
      "0";
  }
  if ( typeof(
         _run_type) == "undefined" ||
       _run_type == "" ) {
    _run_type =
      "spawn";
  }
  if ( typeof(
         _method) == "undefined" ||
       _method == "" ) {
    _method =
      "";
  }
  _msg =
    `Running '${_program}' ` +
    `with arguments '${_args}'.`;
  _msg_info(
    _msg);
  _out =
    "";
  if ( _run_mode == "async" ) {
    // currently not working well id say
    const
      _print =
        function
          (_data) {
          _out = 
            _out +
            _data.toString();
        };
    const
      _close =
        function(
          _code) {
          let
            _array,
            _msg;
          if ( _code != 0 ) {
            _msg =
              `Process exited with code '${_code}'`;
            _msg_error(
              _msg,
              1);
          }
          else {
            _msg =
              `Process exited normally.`;
            _msg_info(
              _msg);
          }
          _array =
            _out.split("\n");
          return _array;
        };
    const
      _process =
        _spawn_async(
          _program,
          _args);
    _process.stdout.on(
      'data',
      _print);
    _process.on(
      'close',
      _close);
    _array =
      _out.split(
        "\n");
    _msg_info(
      _array.length);
    return _array;
  }
  else if ( _run_mode == "sync" ) {
    if ( _run_type == "spawn" ) {
      const
        _process =
          _spawn(
            _program,
            _args,
            { "encoding":
                "utf-8" });
      _array =
        _process.stdout.split(
          "\n");
      return _array;
    }
    else if ( _run_type == "native" ) {
      if ( 0 < _timeout ) {
        _msg_timeout =
          `Timeout of length ` +
          `'${_timeout}' ms reached for task '${_name}'.`;
        _time_over =
          false;
        try {
          const
            _timeout_promise =
              new Promise(
	        (resolve,
                 reject) => {
                  setTimeout(
                    () => {
                      return;
                    },
                    _timeout,
                    "hurr")
                });
          if ( _method != "" ) {
            _out =
              await Promise.race( [
                _sleep(
                  _timeout),
                  _program[
                    _method].apply(
                    _program,
                    _args)
	      ]);
            if ( typeof(
                   _out) == "undefined" ) {
              throw _msg_timeout;
	    }
          }
          else {
            _out =
              await _program.apply(
                _program,
                _args);
          }
        }
        catch(
          _error) {
          _time_over =
            true;
        }
        if ( _time_over ) {
          _msg_warning(
            _msg_timeout);
          return;
        }
        else {
          return _out;
        }
      }
      else {
        _out =
          await _program[
            _method].apply(
            _program,
            _args);
      }
    }
  }
}

function
  _seq(
    _start,
    _end) {
  let
    _item,
    _list;
  _list =
    [];
  if ( _end < _start ) {
    _msg =
      `Second argument 'end' ` +
      `is greater than first ` +
      `argument 'start', returning ` +
      `empty list.`;
    _msg_warning(
      _msg);
    return _list;
  }
  if ( typeof(
         _end) === 'undefined' ) {
    _end =
      _start;
    _start =
      1;
  }
  for ( _item of _range(
                   _start,
                   _end + 1) ) {
    _list.push(
      _item);
  }
  return _list;
}

function
  _sleep(
    _time) {
  return new Promise(
               resolve => setTimeout(
                            resolve,
                            _time));
}

function
  _from_bash_ass_array(
    _bash_array_string) {
  let
    _array,
    _array_name,
    _array_content_re,
    _array_content,
    _array_keys,
    _array_values,
    _key,
    _key_re,
    _keys_matches,
    _keys_re,
    _msg,
    _string,
    _value,
    _value_matches,
    _value_match;
  const
    _array_names =
      [];
  const
    _return =
      {};
  const
    _array_names_re =
      new RegExp(
        `(.+)=\\(`,
        "g");
  const
    _arrays_strings =
      _bash_array_string.match(
        _array_names_re);
  for ( _string of _arrays_strings ) {
    _array_name =
      _string.replace(
        "=(",
        "");
    _array_names.push(
      _array_name);
  }
  for ( _array_name of _array_names ) {
    _return[
      _array_name] =
      {};
    _array_content_re =
      new RegExp(
        `${_array_name}=\\(((.|\n)*?)\\)\n`,
        "g");
    _array_content =
      _bash_array_string.match(
        _array_content_re);
    if ( 1 < _array_content.length ) {
      _msg =
        "Multiple array " +
        `'${_array_name}' definitions ` +
        "detected.";
      _msg_error(
        _msg,
        1);
    }
    else if ( 0 < _array_content.length ) {
      _array =
        _array_content[
          0];
    }
    else {
      _msg =
        "No arrays found in input string.";
      _msg_error(
        _msg,
        1);
    }
    _keys_re =
      new RegExp(
        `\\["(.*?)"\\]`,
        "g");
    _keys_matches =
      _array.match(
        _keys_re);
    _array_keys =
      [];
    for ( _key of _keys_matches ) {
      _key_name =
        _key.replace(
          `["`,
          "");
      _key_name =
        _key_name.replace(
          `"]`,
          "");
      _array_keys.push(
        _key_name);
    }
    for ( _key of _array_keys ) {
      _value_re =
        new RegExp(
          `\\["${_key}"\\]="(.*?)"`,
          "g");
      _value_assignment_matches =
        _array.match(
          _value_re);
      if ( 1 < _value_assignment_matches.length ) {
        _msg =
          "Multiple values " +
          `'${_value_assignment_matches}' assignments found for ` +
          `key '${_key}' of associative array ` +
          `'${_array_name}'.`;
        _msg_error(
          _msg,
          1);
      }
      else if ( 0 < _value_assignment_matches.length ) {
        _value_assignment =
          _value_assignment_matches[
            0];
      }
      else {
        _msg =
          `No values found for key '${_key}'.`;
        _msg_error(
          _msg,
          1);
      }
      _value =
        _value_assignment.replace(
          RegExp(
            `^\\["${_key}"\\]="`,
            "g"),
          "");
      _value =
        _value.replace(
          RegExp(
            `"$`,
            "g"),
          "");
      _return[
        _array_name][
          _key] =
        _value;
    }
  }
  return _return;
}

function
  _to_bash_ass_array(
    _object) {
  let
    _index,
    _key,
    _key_declaration,
    _return;
  _return = [
    "#!/usr/bin/env bash"
  ];
  const
    _arrays_assignments =
      [];
  const
    _arrays_names =
      Object.keys(
        _object);
  const
    _arrays_declaration = [
      "declare \\",
      "  -A \\",
    ];
  const
    _arrays_amount =
      _arrays_names.length;
  const
    _index_max =
      _arrays_amount - 1;
  const
    _indexes =
      _seq(
        0,
        _index_max);
  for ( _index of _indexes ) {
    _array_name =
      _arrays_names[
        _index];
    _array_declaration =
      `  ${_array_name}`;
    if ( _index != _index_max ) {
      _array_declaration +=
        ` \\`;
    }
    _arrays_declaration.push(
      _array_declaration);
    _array_assignment = [
      `${_array_name}=(`
    ];
    _object_keys =
      Object.keys(
        _object[
          _array_name]);
    for ( _key of _object_keys ) {
      _value =
        _object[
          _array_name][
            _key];
      _key_assignment =
        `  ["${_key}"]="${_value}"`;
      _array_assignment.push(
        _key_assignment);
    }
    _array_assignment.push(
      ")");
    _array_assignment_string =
      _array_assignment.join(
        "\n");
    _arrays_assignments.push(
      _array_assignment_string);
  }
  _return =
    _return.concat(
      _arrays_declaration);
  _return =
    _return.concat(
      _arrays_assignments);
  _return =
    _return.join(
      "\n");
  return _return;
}

