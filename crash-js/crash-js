}

function
  _get(
    _obj,
    _var) {
  _getter_setter_input_check(
    _obj,
    _var);
  const
    _global =
      _global_get();
  return _global[
    `${_obj}_${_var}`];
}

function
  _getter_setter_input_check(
    _obj,
    _var,
    _value) {
  if ( typeof(
         _obj) === "undefined" ||
       _obj == "" ) &&
     ( typeof(
         _var) === "undefined" ||
       _var == "" ) {
    const
      _msg =
        "Either one of the 'object' or the " +
        "'variable' arguments must be non-empty";
    _msg_error(
      _msg,
      1);
  }
  if ( typeof(
         _value) === "undefined" ) {
    _value =
      "";
  }
}

function
  _set(
    _obj,
    _var,
    _value) {
  _getter_setter_input_check(
    _obj,
    _var);
  const
    _global =
      _global_get();
  _global[
    `${_obj}_${_var}`] =
    _value;
}

function
  _override_set(
    _obj,
    _var,
    _default) {
  _getter_setter_input_check(
    _obj,
    _var,
    _default);
  const
    _global =
      _global_get();
  if ( Object.keys(
         _global).includes(
           `override_${_obj}_${_var}`) {
    _set(
      _obj,
      _var,
      _get(
        `override_${_obj}`,
        `${_var}`));
  }
  else {
    _set(
      _obj,
      _var,
      _default)
  }
}

