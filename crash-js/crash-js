function 
  _msg_template(
    _type,
    _app_name) {
  let
    _template;
  if ( typeof(
         _app_name) == "undefined" ||
       _app_name == "" ) {
    _template =
      `${_type}: {_msg}`;
  }
  else if ( typeof(
              _app_name) == "string" ||
            _app_name != "" ) {
      _template =
        `[${_app_name}] ${_type}: {_msg}`;
  }
  return _template;
}

function
  _msg_warning(
    _msg) {
  let
    _out;
  if ( quiet == "n" ) {
    _template =
      _msg_template(
        "WARNING",
        app_name);
    _out =
      _template.replaceAll(
        "{_msg}",
        _msg);
    console.warn(
      _out);
  }
}

function
  _msg_info(
    _msg) {
  let
    _out;
  if ( typeof(
         quiet) == "undefined" ||
       quiet == "" ) {
    quiet =
      "y";
  }
  if ( quiet == "n" ) {
    const
      _template =
        _msg_template(
          "INFO",
          app_name);
    _out =
      _template.replaceAll(
        "{_msg}",
        _msg);
    console.log(
      _out);
  }
}

function
  _msg_error(
    _msg,
    _exit) {
  let
    _template,
    _out;
  if ( typeof(
         app_name) == "undefined" ||
         app_name == "" ) {
    const
      app_name =
        "";
  }
  _exit =
    String(
      _exit);
  _template =
    _msg_template(
      "ERROR",
      app_name);
  _out =
    _template.replaceAll(
      "{_msg}",
      _msg);
  if ( _exit === "1" ) {
    console.error(
      _out);
    _process_exit(
      1);
  }
  else if ( _exit === "0" ) {
    console.warn(
      _out);
  }
}

