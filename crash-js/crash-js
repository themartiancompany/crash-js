function
  _error_display(
    _error) {
  let
    _message;
  if ( typeof(error) == "object" ) {
    if ( 'error' in _error && 
         _error[
           'error'] != undefined &&
         'message' in _error[
                        'error'] ) {
      _message =
        _error[
          'error'][
            'message'];
    }
    else if ( 'shortMessage' in _error ) {
      _message =
        _error[
          'shortMessage'];
    }
    else {
      _message =
        _error;
    }
    console.error(
      _error);
  }
  else {
    _message =
      _error;
    console.error(
      _error);
  }
  _msg_error(
    _message,
    0);
}

function
  _cmdline_check(
    _app_name) {
  let
    _argv,
    _program,
    _program_name;
  if ( typeof window === 'undefined' ) {
    _argv =
      _argv_get();
    _program =
      _argv[
        1];
    if ( typeof(
           _program) === 'undefined' ) {
      _program =
        _argv[
          "$0"];
    }
    _program_name =
      _basename(
        _program);
    if ( _program_name == _app_name ) {
      return true;
    }
    else {
      return false;
    }
  }
  else {
    return false;
  }
}

function
  _get_date_human() {
  const
    _date =
      new Date();
  const
    _year =
