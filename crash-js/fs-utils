const
  _fs =
    require(
      "fs");
const
  _fs_worker_new =
    _fs.fsWorkerNew;
const
  _fs_worker_start =
    _fs.fsWorkerStart;
const
  _stat =
    _fs.statSync;
const
  _json_parse =
    JSON.parse;
const
  _json_display =
    JSON.stringify;
const
  _path_module =
    require(
      "path");
const
  _path_module_basename =
    _path_module.basename;
const
  _path_module_dirname =
    _path_module.dirname;
const
  _path_module_join =
    _path_module.join;
const
  _path_module_parse =
    _path_module.parse;

function
  _basename(
    _file_path) {
  let
    _dir;
  _dir =
    _path_module_basename(
      _file_path);
  return _dir;
}

function
  _dirname(
    _file_path) {
  let
    _dir;
  _dir =
    _path_module_dirname(
      _file_path);
  return _dir;
}

function
  _ext_rm(
    _path) {
  let
    _dir,
    _name,
    _paths;
  _dir =
    _path_module_parse(
      _path).dir;
  _name =
    _path_module_parse(
      _path).name;
  _paths = [
    _dir,
    _name];
  return _path_join(
    _paths); 
}

function
  _file_exists(
    _path) {
  let
    _exists,
    _return;
  _return =
    false;
  _exists =
    _fs.existsSync(
      _path);
  if (_exists) {
    _return =
      true;
  }
  return _return;
}

function
  _file_read(
    _path) {
  let
    _read_opts,
    _return;
  _read_opts =
   {"encoding":
      "utf8",
    "flag":
      'r'};
  _return =
    _fs.readFileSync(
      _path,
      _read_opts);
  return _return;
}

function
  _file_write(
    _path,
    _content) {
  _fs.writeFileSync(
    _path,
    _content);
}

function
  _json_read(
    _json_path) {
  let
    _json_str,
    _json;
  _json_str =
    _file_read(
      _json_path);
  _json =
    _json_parse(
      _json_str);
  return _json;
}

function
  _ls(
    _args) {
  let
    _read_dir,
    _return;
  if ( typeof(
       _fs.readdirSync) === 'undefined' ) {
    _read_dir =
      _fs.readDirSync;
    _return =
      _read_dir.apply(
        null,
        _args).unwrap()
  }
  else {
    _read_dir =
      _fs.readdirSync
    _return =
      _read_dir.apply(
        null,
        _args);
  }
  return _return;
} 

function
  _path_join(
    _paths) {
  let
    _path;
  _path =
    _path_module_join.apply(
      null,
      _paths);
  return _path;
}

function
  _split(
    _in,
    _parts,
    _out) {
  console.log(
    "hi");
}

module.exports = {
  _basename:
    _basename,
  _dirname:
    _dirname,
  _ext_rm:
    _ext_rm,
  _file_exists:
    _file_exists,
  _file_read:
    _file_read,
  _file_write:
    _file_write,
  _fs_worker_new:
    _fs_worker_new,
  _fs_worker_start:
    _fs_worker_start,
  _json_display:
    _json_display,
  _json_read:
    _json_read,
  _ls:
    _ls,
  _mkdir:
    _fs.mkdirSync,
  _path_join:
    _path_join,
  _split:
    _split,
  _stat:
    _stat
};
