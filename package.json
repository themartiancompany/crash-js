{
  "name":
    "crash-js",
  "version":
    "0.11.111111111",
  "description":
    "Crash Javascript library.",
  "funding":
    { "type":
        "patreon",
      "url":
        "https://patreon.com/tallero"
  },
  "files": [
    "AUTHORS.rst",
    "COPYING",
    "README.md",
    "eslint.config.mjs",
    "fs-worker.webpack.config.cjs",
    "crash-js",
    "dist",
    "examples",
    "man",
    "package.json",
    "webpack.config.cjs"
  ],
  "man":
    "./man/libcrash-js.1",
  "keywords": [
    "crash-bash",
    "crash-javascript",
    "dogeos",
    "evmfs",
    "hip",
    "opfs",
    "fs",
    "node:fs",
    "tmcfs",
    "themartiancompany",
    "ur"
  ],
  "homepage":
    "https://github.com/themartiancompany/crash-js",
  "bugs": {
    "url":
      "https://github.com/themartiancompany/crash-js/issues"
  },
  "repository": {
    "type":
      "git",
    "url":
      "git+https://github.com/themartiancompany/crash-js.git"
  },
  "license":
    "AGPL-3.0-or-later",
  "author":
    { "name":
        "Pellegrino Prevete",
      "email":
        "pellegrinoprevete@gmail.com",
      "url":
        "https://github.com/tallero"
  },
  "devDependencies": {
    "crash-js-webpack":
      "^0.0.37",
    "eslint":
      "^10.3.0",
    "@eslint/js":
      "^10.0.1",
    "globals":
      "^17.3.0",
    "safely-serve":
      "^0.0.10",
    "webpack":
      "^5.102.1",
    "webpack-cli":
      "^6.0.1"
  },
  "dependencies": {
    "tmcfs":
      "npm:@themartiancompany/fs@^0.0.18",
    "yargs":
      "18.0.0"
  },
  "overrides": {
    "crash-js":
      "./crash-js/crash-js"
  },
  "yargs": {
    "parse-numbers":
      false,
    "parse-positionalnumbers":
      false
  },
  "type":
    "commonjs",
  "main":
    "crash-js/crash-js",
  "scripts":
    {
      "build-fs-worker":
        "npx webpack --mode 'production' --config 'fs-worker.webpack.config.cjs' --stats-error-details && mv 'fs-worker.js' 'dist/crash-js'",
      "build":
        "npm run lint; npm run build-fs-worker; npm run build-lib",
      "build-lib":
        "npx webpack --mode 'production' --config 'webpack.config.cjs' --stats-error-details; mkdir -p 'dist'; mv 'crash-js.js' 'dist/crash-js'",
      "lint":
        "npx eslint .",
      "start":
        "npx safely-serve 'dist/crash-js'",
      "test":
        "echo \"Error: no test specified\" && exit 1" }
}
